# ── LLM Provider ──────────────────────────────────────────
# Supported providers: deepseek, gemini, kimi, glm, qwen, openai
# Set LLM_PROVIDER to one of the above, then fill in your API key.
# Model and base_url are auto-detected from the provider preset
# unless you override them explicitly.
#
# Presets:
#   deepseek  →  api.deepseek.com        / deepseek-chat
#   gemini    →  generativelanguage...    / gemini-2.0-flash
#   kimi      →  api.moonshot.cn/v1      / moonshot-v1-8k
#   glm       →  open.bigmodel.cn/...    / glm-4-flash
#   qwen      →  dashscope.aliyuncs.com  / qwen-turbo
#   openai    →  api.openai.com/v1       / gpt-4o-mini

LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here
# LLM_MODEL=deepseek-chat          # optional: override default model
# LLM_BASE_URL=https://api.deepseek.com  # optional: override default base_url
# LLM_TIMEOUT=30                   # optional: request timeout in seconds

# ── Speech Services (Backend STT/TTS) ────────────────────
STT_ENABLED=true
STT_MODEL=paraformer-zh
STT_VAD_MODEL=fsmn-vad
STT_PUNC_MODEL=ct-punc
STT_DEVICE=cuda

TTS_ENABLED=true
TTS_MODEL=CosyVoice-300M
TTS_DEFAULT_VOICE=default
TTS_DEVICE=cuda
TTS_SAMPLE_RATE=22050
TTS_CHANNELS=1
TTS_SAMPLE_WIDTH=2

SPEECH_FALLBACK_TO_BROWSER=true
SPEECH_MAX_UPLOAD_BYTES=10485760
